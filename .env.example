# =========================================================================
# FlowCRM environment configuration. Copy to `.env` and fill in real values.
# =========================================================================

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Database (async asyncpg driver) ---
# Local docker-compose:
DATABASE_URL=postgresql+asyncpg://flowcrm:flowcrm@localhost:5432/flowcrm
# Supabase (use the asyncpg driver; the transaction pooler on :6543 requires
# DB_STATEMENT_CACHE_SIZE=0 because prepared statements are not supported there):
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Restricted role the request session switches into so PostgreSQL RLS applies.
DB_APP_ROLE=flowcrm_app
# Set to 0 when running behind PgBouncer / the Supabase transaction pooler.
DB_STATEMENT_CACHE_SIZE=0
# Set true for cloud Postgres (Supabase / Neon), which requires TLS.
DB_SSL=false
DB_ECHO=false

# --- Redis / ARQ ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI ---
# If unset, AI features fall back to a local heuristic so the app still runs.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_ALG=HS256

# --- Webhook signing secrets (HMAC verification) ---
META_APP_SECRET=
WHATSAPP_APP_SECRET=
CALENDLY_SIGNING_KEY=
FORMS_WEBHOOK_SECRET=
